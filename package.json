{
  "name": "@dashx/react-native",
  "title": "DashX React Native",
  "version": "1.3.2",
  "description": "DashX SDK for React Native",
  "main": "index.js",
  "types": "index.d.ts",
  "files": [
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/__tests__",
    "!**/.*",
    "!android/build",
    "!android/gradle",
    "!android/gradlew.bat",
    "!android/gradlew",
    "!android/local.properties",
    "!ios/build",
    "*.podspec",
    "android",
    "DashXReactNative.podspec",
    "index.js",
    "index.d.ts",
    "ios",
    "src",
    "README.md"
  ],
  "codegenConfig": {
    "name": "RNDashXReactNativeSpec",
    "type": "modules",
    "jsSrcsDir": "src",
    "android": {
      "javaPackageName": "com.dashx.rn.sdk"
    }
  },
  "scripts": {
    "test": "jest",
    "lint": "eslint index.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/dashxhq/dashx-react-native"
  },
  "keywords": [
    "react-native",
    "ios",
    "android"
  ],
  "author": {
    "name": "Team DashX",
    "email": "dev@dashx.com"
  },
  "license": "MIT",
  "licenseFilename": "LICENSE",
  "homepage": "https://github.com/dashxhq/dashx-react-native#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-native": ">=0.74.0"
  },
  "devDependencies": {
    "@commitlint/config-conventional": "^17.0.2",
    "@react-native/eslint-config": "0.77.3",
    "del-cli": "^5.0.0",
    "eslint": "^8.4.1",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-prettier": "^4.0.0",
    "jest": "^28.1.1",
    "pod-install": "^0.1.0",
    "prettier": "^2.0.5",
    "react": "18.3.1",
    "react-native": "0.77.3",
    "turbo": "^1.10.7"
  },
  "engines": {
    "node": ">= 16.0.0"
  },
  "dependencies": {},
  "eslintConfig": {
    "root": true,
    "extends": [
      "@react-native",
      "prettier"
    ],
    "plugins": [
      "prettier"
    ],
    "rules": {
      "prettier/prettier": [
        "error",
        {
          "quoteProps": "consistent",
          "singleQuote": true,
          "tabWidth": 2,
          "trailingComma": "es5",
          "useTabs": false
        }
      ]
    }
  },
  "eslintIgnore": [
    "node_modules/",
    "lib/"
  ],
  "prettier": {
    "quoteProps": "consistent",
    "singleQuote": true,
    "trailingComma": "es5"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {
      "^.+\\.js$": "babel-jest"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!react-native)"
    ]
  }
}
